# Database Configuration
DATABASE_URL=postgresql://crop_user:crop_password@localhost:5432/crop_predict_db

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Application Configuration
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS Configuration
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# Logging
LOG_LEVEL=INFO
